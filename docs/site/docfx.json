{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "src": "../../src",
          "files": [
            "FluentGpu.Dsl/FluentGpu.Dsl.csproj",
            "FluentGpu.Hooks/FluentGpu.Hooks.csproj",
            "FluentGpu.Controls/FluentGpu.Controls.csproj",
            "FluentGpu.Hosting/FluentGpu.Hosting.csproj",
            "FluentGpu.Foundation/FluentGpu.Foundation.csproj",
            "FluentGpu.Media/FluentGpu.Media.csproj",
            "FluentGpu.Scene/FluentGpu.Scene.csproj",
            "FluentGpu.Layout/FluentGpu.Layout.csproj",
            "FluentGpu.Render/FluentGpu.Render.csproj",
            "FluentGpu.Reconciler/FluentGpu.Reconciler.csproj",
            "FluentGpu.Rhi/FluentGpu.Rhi.csproj",
            "FluentGpu.Pal/FluentGpu.Pal.csproj",
            "FluentGpu.Text/FluentGpu.Text.csproj",
            "FluentGpu.Input/FluentGpu.Input.csproj",
            "FluentGpu.Animation/FluentGpu.Animation.csproj",
            "FluentGpu.Rhi.D3D12/FluentGpu.Rhi.D3D12.csproj",
            "FluentGpu.Text.DirectWrite/FluentGpu.Text.DirectWrite.csproj",
            "FluentGpu.Pal.Windows/FluentGpu.Pal.Windows.csproj",
            "FluentGpu.Win32.Interop/FluentGpu.Win32.Interop.csproj",
            "FluentGpu.Media.Codecs.Wic/FluentGpu.Media.Codecs.Wic.csproj",
            "FluentGpu.Accessibility.Uia/FluentGpu.Accessibility.Uia.csproj"
          ]
        }
      ],
      "dest": "api",
      "outputFormat": "mref",
      "properties": {
        "TargetFramework": "net10.0"
      }
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "api/**.yml",
          "api/index.md"
        ]
      },
      {
        "files": [
          "**/*.md",
          "**/toc.yml"
        ],
        "exclude": [
          "api/**",
          "obj/**",
          "_site/**"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata": {
      "_appName": "FluentGpu",
      "_appTitle": "FluentGpu Developer Docs",
      "_appFooter": "FluentGpu — a near-zero-allocation, NativeAOT, GPU-rendered UI engine for .NET 10. Usage docs live here; architecture canon lives in design/ (SPEC-INDEX.md is the precedence authority).",
      "_enableSearch": true,
      "_disableContribution": true
    }
  }
}
