# .NET build output
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
artifacts/
*.user
*.suo
.vs/

# NuGet
*.nupkg
packages/

# Rider / VS
.idea/

# Runtime diagnostics dumps (process dumps, GC dumps, perf counters)
*.dmp
*.gcdump
fluentgpu-*-counters.csv

# Wavee probe output (WAVEE_*_PROBE CSV/summary dumps — regenerated on demand)
.wavee-diagnostics/

# --screenshot fidelity captures (generated PNGs for visual diffing)
out/
.shots/
.tmp-shots/

# MSIX packaging prototype: self-contained publish output (loose-register install location)
.pkg-publish*/

# MSIX pipeline (build/pack-msix.ps1): publish+layout staging area (artifacts/ already ignored above).
# NOTE: build/appicon-source.png and src/**/assets/AppIcon/*.png|*.ico ARE committed (the app's icon source + assets).
.msix-build/
.tmp-*

# Trusted Signing account config (not secret, but keep it local; commit the .template instead).
build/signing/metadata.json

# PlayPlay runtime payloads (manifest carries pins — never commit real copies).
**/playplay-runtime.json
private-runtimes/

# Legacy audio-runtime pack dir (superseded by manifest-driven bare DLL layout).
app/audio-runtime/

# Local PlayPlay native-derivation package. This contains version/arch-specific
# reverse-engineering glue and is intentionally kept out of source control.
app/Wavee.PlayPlay/

# Out-of-scope native/derivation material — lives in the separate private
# workspace (wavee-playplay-private), junctioned in on demand. Never commit here.
app/.native/
app/tmp_*
scripts/pyghidra*
tools/pyghidra*
tools/playplay_*
tools/x64_*
tools/fill_random_sweep.py
tools/*_decomp.json
tools/*_derive_*.json
playplay-probe-out*.txt
app/docs/spotiload-offline-path.md
app/docs/playplay-*.md
app/docs/wavee-playplay-*.md

# On-demand junction helper for the private package (machine-local).
link-playplay.ps1
.playplay-link
