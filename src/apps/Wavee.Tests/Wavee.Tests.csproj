<Project Sdk="Microsoft.NET.Sdk">

  <!-- Unit tests for the Wavee backend core. Source-includes src/apps/Wavee/Backend (which is engine-independent: deps =
       Wavee.Core + BCL only), so the test assembly stays lean — no FluentGpu/TerraFX/GPU. Honors "no separate backend
       csproj": the Backend stays part of src/apps/Wavee; this project just compiles the same sources for testing. -->
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <IsPackable>false</IsPackable>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <!-- CA1416: source-includes the cross-platform Backend, whose portability is guarded by TerraFX-freedom, not this
         analyzer. xUnit1051: the v3 "pass TestContext.Current.CancellationToken" nag is noise for these deterministic,
         non-cancellable unit tests. -->
    <DefineConstants>$(DefineConstants);WAVEE_TESTS</DefineConstants>
    <NoWarn>$(NoWarn);CA1416;xUnit1051</NoWarn>
  </PropertyGroup>

  <PropertyGroup Condition="Exists('..\Wavee.PlayPlay\Client\InProcessPlayPlayKeyDeriver.cs')">
    <DefineConstants>$(DefineConstants);WAVEE_PLAYPLAY_LOCAL</DefineConstants>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.14.1" />
    <PackageReference Include="xunit.v3" Version="3.0.0" />
    <PackageReference Include="xunit.runner.visualstudio" Version="3.1.3" />
    <PackageReference Include="Microsoft.Data.Sqlite" Version="10.0.8" />   <!-- the Backend source-include now contains SqliteColdStore -->
    <PackageReference Include="ZstdSharp.Port" Version="0.8.6" />           <!-- the Backend source-include now contains SpotifyZstd -->
    <!-- NU1903: pin the patched SQLite bundle 3.0.0 (overrides the transitive 2.1.11 carrying the known SQLite vulnerability). -->
    <PackageReference Include="SQLitePCLRaw.bundle_e_sqlite3" Version="3.0.0" />
    <!-- the Backend source-include also contains ExtendedMetadataSource → compile the metadata protos here too -->
    <PackageReference Include="Google.Protobuf" Version="3.35.0" />
    <PackageReference Include="Grpc.Tools" Version="2.81.0">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <Protobuf Include="..\Wavee\SpotifyLive\Protos\extended_metadata.proto" GrpcServices="None" ProtoRoot="..\Wavee\SpotifyLive\Protos" />
    <Protobuf Include="..\Wavee\SpotifyLive\Protos\entity_extension_data.proto" GrpcServices="None" ProtoRoot="..\Wavee\SpotifyLive\Protos" />
    <Protobuf Include="..\Wavee\SpotifyLive\Protos\extension_kind.proto" GrpcServices="None" ProtoRoot="..\Wavee\SpotifyLive\Protos" />
    <Protobuf Include="..\Wavee\SpotifyLive\Protos\metadata.proto" GrpcServices="None" ProtoRoot="..\Wavee\SpotifyLive\Protos" />
    <Protobuf Include="..\Wavee\SpotifyLive\Protos\lean_metadata.proto" GrpcServices="None" ProtoRoot="..\Wavee\SpotifyLive\Protos" />
    <!-- feature extension payloads carried over the SAME extended-metadata transport (album recommended-playlist hydration) -->
    <Protobuf Include="..\Wavee\SpotifyLive\Protos\recommended_playlists.proto" GrpcServices="None" ProtoRoot="..\Wavee\SpotifyLive\Protos" />
    <Protobuf Include="..\Wavee\SpotifyLive\Protos\list_metadata_v2.proto" GrpcServices="None" ProtoRoot="..\Wavee\SpotifyLive\Protos" />
    <!-- music-video associations (VIDEO_ASSOCIATIONS payload) — VideoAssociationTests parses this against the wire -->
    <Protobuf Include="..\Wavee\SpotifyLive\Protos\video_associations.proto" GrpcServices="None" ProtoRoot="..\Wavee\SpotifyLive\Protos" />
    <!-- playlist membership + collection delta wire types (the Backend mapping logic is unit-tested here) -->
    <Protobuf Include="..\Wavee\SpotifyLive\Protos\playlist_permission.proto" GrpcServices="None" ProtoRoot="..\Wavee\SpotifyLive\Protos" />
    <Protobuf Include="..\Wavee\SpotifyLive\Protos\playlist4_external.proto" GrpcServices="None" ProtoRoot="..\Wavee\SpotifyLive\Protos" />
    <Protobuf Include="..\Wavee\SpotifyLive\Protos\collection2v2.proto" GrpcServices="None" ProtoRoot="..\Wavee\SpotifyLive\Protos" />
    <!-- audio playback resolution: storage-resolve + AUDIO_FILES (FLAC) — LiveTrackResolverTests parse these -->
    <Protobuf Include="..\Wavee\SpotifyLive\Protos\storage-resolve.proto" GrpcServices="None" ProtoRoot="..\Wavee\SpotifyLive\Protos" />
    <Protobuf Include="..\Wavee\SpotifyLive\Protos\audio_files_extension.proto" GrpcServices="None" ProtoRoot="..\Wavee\SpotifyLive\Protos" />
    <Protobuf Include="..\Wavee\SpotifyLive\Protos\devices.proto" GrpcServices="None" ProtoRoot="..\Wavee\SpotifyLive\Protos" />
    <Protobuf Include="..\Wavee\SpotifyLive\Protos\media.proto" GrpcServices="None" ProtoRoot="..\Wavee\SpotifyLive\Protos" />
    <Protobuf Include="..\Wavee\SpotifyLive\Protos\player.proto" GrpcServices="None" ProtoRoot="..\Wavee\SpotifyLive\Protos" />
    <Protobuf Include="..\Wavee\SpotifyLive\Protos\connect.proto" GrpcServices="None" ProtoRoot="..\Wavee\SpotifyLive\Protos" />
    <Protobuf Include="..\Wavee\SpotifyLive\Protos\autoplay.proto" GrpcServices="None" ProtoRoot="..\Wavee\SpotifyLive\Protos" />

  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Wavee.Core\Wavee.Core.csproj" />
    <ProjectReference Include="..\..\FluentGpu.WindowsApi\FluentGpu.WindowsApi.csproj" />
    <!-- the vendored Ogg/Vorbis fork — OggContainerSeekTests drive its container-level seek paths directly -->
    <ProjectReference Include="..\vendor\NVorbis\NVorbis\NVorbis.csproj" />
    <Compile Include="..\Wavee\Diagnostics\*.cs" />
    <Compile Include="..\Wavee\Backend\**\*.cs" />
    <!-- The REAL production VirtualCollection<T> (portable, Signals-only), source-included so DiscographyPaginationTests
         can exercise its provisional-seed reconciliation directly. Its lone dependency (FluentGpu.Signals.Signal<T>) is
         satisfied by VirtualCollectionSignalShim.cs — so we test the real reconciliation code without referencing the
         FluentGpu.Engine assembly (which would shadow the source-included Backend's Channel / DealerRouter). -->
    <Compile Include="..\..\FluentGpu.Controls\VirtualCollection.cs" />
    <!-- the pure (FluentGpu-free) QR encoder, source-included so QrTests can round-trip-decode its output -->
    <Compile Include="..\Wavee\Features\Auth\Qr.cs" />
    <!-- the pure keyed tracklist diff (Wavee.Core + BCL only) behind the §4.6 choreography — MembershipDiffTests -->
    <Compile Include="..\Wavee\Components\MembershipDiff.cs" />
    <!-- detail layout breakpoint hysteresis (Wavee.Core + BCL only) — DetailLayoutBreakpointTests -->
    <Compile Include="..\Wavee\Features\Detail\DetailLayoutBreakpoints.cs" />
    <!-- concert schedule/detail hysteresis + wide-editorial metrics (BCL only) -->
    <Compile Include="..\Wavee\Features\Concerts\ConcertLayout.cs" />
    <Compile Include="..\Wavee\Features\Concerts\ConcertRoutes.cs" />
    <!-- pure schedule shaping (chronological sort/dedup) + geolocation-status → message map (Wavee.Core + FluentGpu.Pal) -->
    <Compile Include="..\Wavee\Features\Concerts\ConcertScheduleModel.cs" />
    <!-- pure detail shaping: ticket-URL validation, price/availability/sale-window formatting, status/location lines -->
    <Compile Include="..\Wavee\Features\Concerts\ConcertDetailModel.cs" />
    <!-- pure hub decisions: concept toggle/survival, inferred location label, feed emptiness -->
    <Compile Include="..\Wavee\Features\Concerts\ConcertHubModel.cs" />
    <!-- library collapse breakpoint hysteresis (BCL only) — LibraryLayoutBreakpointTests -->
    <Compile Include="..\Wavee\Features\Library\LibraryLayoutBreakpoints.cs" />
    <!-- vertical track-detail hero layout resolver (BCL only) — DetailVerticalLayoutTests -->
    <Compile Include="..\Wavee\Features\Detail\DetailVerticalLayout.cs" />
    <!-- the activity-undo executor (engine-free: IUndoTarget + IMusicLibrary + ActivityLog) — ActivityUndoTests drive it -->
    <Compile Include="..\Wavee\App\ActivityUndo.cs" />
    <!-- The engine-free core of the context-menu action system (Wavee.Core + BCL only) — Actions/*Tests drive the
         selection semantics, link building, and enablement rules. SelectionModel (portable, Signals-only) rides the
         same VirtualCollectionSignalShim; TrackTargetResolver is the one file that consumes it. -->
    <Compile Include="..\Wavee\Actions\ActionId.cs" />
    <Compile Include="..\Wavee\Actions\ActionTarget.cs" />
    <Compile Include="..\Wavee\Actions\ActionRules.cs" />
    <Compile Include="..\Wavee\Actions\SpotifyLink.cs" />
    <Compile Include="..\Wavee\Actions\TrackTargetResolver.cs" />
    <Compile Include="..\..\FluentGpu.Controls\SelectionModel.cs" />
    <!-- the device-gated queue verbs (Wavee.Core + BCL only) — the PlayNext/AddToEnd no-device regression tests -->
    <Compile Include="..\Wavee\Features\Detail\DetailQueueActions.cs" />
    <!-- artist hero height response (Wavee.Core + BCL only) — ArtistHeroLayoutTests -->
    <Compile Include="..\Wavee\Features\Detail\ArtistHeroLayout.cs" />
    <!-- the live music-video data service (Backend-only deps), source-included so VideoAssociationTests can drive it -->
    <Compile Include="..\Wavee\SpotifyLive\SpotifyVideoService.cs" />
    <Compile Include="..\Wavee\SpotifyLive\SpotifyUserProfileService.cs" />
    <!-- the live presence/friend-activity feed (Backend + Wavee.Core deps only) — FriendActivityServiceTests drive it -->
    <Compile Include="..\Wavee\SpotifyLive\SpotifyFriendActivityService.cs" />
    <!-- the live notification feeds (gander + what's-new) — Gander/WhatsNew tests drive them -->
    <Compile Include="..\Wavee\SpotifyLive\SpotifyNotificationsService.cs" />
    <Compile Include="..\Wavee\SpotifyLive\SpotifyWhatsNewService.cs" />
    <Compile Include="..\Wavee\SpotifyLive\PathfinderClient.cs" />
    <Compile Include="..\Wavee\SpotifyLive\PathfinderResource.cs" />
    <Compile Include="..\Wavee\SpotifyLive\ConcertPathfinderRequests.cs" />
    <Compile Include="..\Wavee\SpotifyLive\ConcertPathfinderMapper.cs" />
    <Compile Include="..\Wavee\SpotifyLive\SpotifyConcertService.cs" />
    <Compile Include="..\Wavee\SpotifyLive\ExtractedColorCache.cs" />
    <!-- audio resilience surfaces (all protobuf-free) source-included so the key-resolver / provisioner / IPC-manager
         resilience + error paths are unit-tested without referencing the Windows Wavee assembly. -->
    <Compile Include="..\Wavee\SpotifyLive\Audio\ILicenseClient.cs" />
    <Compile Include="..\Wavee\SpotifyLive\Audio\IPlayPlayKeyDeriver.cs" />
    <Compile Include="..\Wavee\SpotifyLive\Audio\AudioRuntimeStatusService.cs" />
    <Compile Include="..\Wavee\SpotifyLive\Audio\LicenseKeyDiskCache.cs" />
    <Compile Include="..\Wavee\SpotifyLive\Audio\AudioKeyResolver.cs" />
    <Compile Include="..\Wavee\SpotifyLive\Audio\HeadFileClient.cs" />
    <Compile Include="..\Wavee\SpotifyLive\Audio\IPlayPlayProvisioner.cs" />
    <Compile Include="..\Wavee\SpotifyLive\Audio\AudioFormatProbe.cs" />
    <Compile Include="..\Wavee\SpotifyLive\Audio\Runtime\*.cs" />
    <!-- the track resolver (extended-metadata file discovery + Ogg/FLAC selection) — LiveTrackResolverTests drive it -->
    <!-- Audio output-device state machine + its COM-free contract, and the picker service/model (all engine-independent)
         source-included so OutputDeviceRouterTests / SessionVolumeSyncTests / DevicePickerItemsTests / ConnectControllerTests
         drive them without the WASAPI COM interop or the FluentGpu.Engine reference. -->
    <Compile Include="..\Wavee\SpotifyLive\Audio\AudioDeviceMonitor.cs" />
    <Compile Include="..\Wavee\SpotifyLive\Audio\OutputDeviceRouter.cs" />
    <Compile Include="..\Wavee\App\LocalAudioDeviceService.cs" />
    <Compile Include="..\Wavee\App\DevicePickerModel.cs" />
    <Compile Include="..\Wavee\SpotifyLive\LiveTrackResolver.cs" />
    <Compile Include="..\Wavee\SpotifyLive\LiveContextResolver.cs" />
    <Compile Include="..\Wavee\SpotifyLive\SpotifyClientIdentity.cs" />
    <Compile Include="..\Wavee\SpotifyLive\ConnectStateBuilder.cs" />
  </ItemGroup>

  <ItemGroup>
    <None Include="Fixtures\**\*" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <!-- The loc-keys generator (same wiring as src/apps/Wavee): source-included files reference the generated `Strings`
       consts, so the test compilation needs the same base catalog + analyzer. Loc.Get falls back to the key at
       runtime here — tests assert distinctness/shape, never localized copy. -->
  <PropertyGroup>
    <FluentGpuLocNamespace>Wavee</FluentGpuLocNamespace>
  </PropertyGroup>
  <ItemGroup>
    <AdditionalFiles Include="..\Wavee\assets\loc\en-US.json" FluentGpuLocBase="true" />
    <CompilerVisibleItemMetadata Include="AdditionalFiles" MetadataName="FluentGpuLocBase" />
    <CompilerVisibleProperty Include="FluentGpuLocNamespace" />
    <ProjectReference Include="..\..\FluentGpu.SourceGen\FluentGpu.SourceGen.csproj"
                      OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
  </ItemGroup>

  <ItemGroup Condition="Exists('..\Wavee.PlayPlay\Client\InProcessPlayPlayKeyDeriver.cs')">
    <!-- The test assembly source-includes only the PlayPlay pieces the PlayPlay*Tests exercise; the CLI probe
         (app-only AppDataSettings dep) and the in-process native adapter are app-composition-only, excluded here. -->
    <!-- The test assembly source-includes the PlayPlay pieces the PlayPlay*Tests exercise; the CLI probe
         (app-only AppDataSettings dep) is app-composition-only, excluded here. -->
    <Compile Include="..\Wavee.PlayPlay\**\*.cs" Exclude="..\Wavee.PlayPlay\**\bin\**;..\Wavee.PlayPlay\**\obj\**;..\Wavee.PlayPlay\Client\PlayPlayRuntimeProbe.cs" Link="Wavee.PlayPlay\%(RecursiveDir)%(Filename)%(Extension)" />
    <Protobuf Include="..\Wavee.PlayPlay\Protos\playplay.proto" GrpcServices="None" ProtoRoot="..\Wavee.PlayPlay\Protos" Condition="Exists('..\Wavee.PlayPlay\Protos\playplay.proto')" />
  </ItemGroup>

</Project>
